{
  "expo": {
    "name": "Swag Chat",
    "slug": "swag-chat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "swagchat",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.swagchat.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Swag uses your camera for video calls and identity verification.",
        "NSMicrophoneUsageDescription": "Swag uses your microphone for voice and video calls.",
        "NSPhotoLibraryUsageDescription": "Share photos from your gallery in chat",
        "NSLocationWhenInUseUsageDescription": "Share your live location with friends in chat"
      }
    },
    "android": {
      "package": "com.swagchat.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.BLUETOOTH_CONNECT"
      ]
    },
    "web": {
      "name": "Swag Chat",
      "shortName": "Swag Chat",
      "description": "Swag Chat — verified, private messaging.",
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ],
      "expo-font",
      "expo-audio",
      "expo-video",
      "expo-localization",
      "expo-asset",
      "@stream-io/video-react-native-sdk",
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": "Swag uses your camera for video calls and identity verification.",
          "microphonePermission": "Swag uses your microphone for voice and video calls."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3d34c3a4-3a45-4c71-8419-09aca79a99af"
      }
    }
  }
}
